// don't try to fix these warnings. They will only break it.
// upgrade typescript? I have fear. 
{
  "compilerOptions": {
    "target": "ES6",
    "allowJs": true,
    "module": "commonjs", // "esnext", // "commonjs",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "paths": {
      "*": ["./node_modules/*"]
    },
    "jsx": "react",
    "lib": [
      "es2017","dom"
    ],
  },
  "include": ["src/**/*","src/knotfree-ts-lib/**/*"],
}
